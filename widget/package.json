{
  "name": "weather-widget",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.weather.widget",
    "productName": "天气插件",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../天气插件.html",
        "to": "app.html"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "sign": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "天气插件.exe"
    },
    "asar": false
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.35.3",
    "to-ico": "^1.1.5"
  }
}
